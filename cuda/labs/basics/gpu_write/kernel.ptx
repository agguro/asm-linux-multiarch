.version 6.5
.target sm_61
.address_size 64

.visible .entry gpu_write(
    .param .u64 a,
    .param .u64 b,
    .param .u64 c,
    .param .u32 n
) {
    .reg .u64 %rd1;
    .reg .f32 %f1;

    // Load the destination pointer 'c'
    ld.param.u64 %rd1, [c];

    // Prepare the value 42.0
    mov.f32 %f1, 42.0;

    // Write 42.0 to the memory address in %rd1 (the first element of d_c)
    st.global.f32 [%rd1], %f1;

    ret;
}