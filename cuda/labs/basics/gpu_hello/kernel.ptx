/*
 * kernel.ptx
 * get the thread ID from the running thread and return it to the cpu
  */

.version 6.5
.target sm_61
.address_size 64

.visible .entry gpu_hello(.param .u64 result_ptr) {
    .reg .u64 %base;
    .reg .u32 %t;
    .reg .u64 %off;
    .reg .u64 %dest;

    // result_ptr is the address in the parameter buffer.
    // We load the actual GPU address (d_ptr) from it.
    ld.param.u64 %base, [result_ptr];
    
    mov.u32 %t, %tid.x;
    
    // Calculate offset: tid * 4 bytes
    mul.wide.u32 %off, %t, 4;
    add.u64 %dest, %base, %off;

    // Write the thread ID to the buffer
    st.global.u32 [%dest], %t;
    ret;
}