.version 6.5
.target sm_61
.address_size 64

.visible .entry gpu_thread_write(
    .param .u64 a,
    .param .u64 b,
    .param .u64 c,
    .param .u32 n
) {
    .reg .u32 %r<4>;
    .reg .u64 %rd<4>;
    .reg .f32 %f1;

    // 1. Get Global ID: i = blockIdx.x * blockDim.x + threadIdx.x
    mov.u32 %r0, %ctaid.x;
    mov.u32 %r1, %ntid.x;
    mov.u32 %r2, %tid.x;
    mad.lo.u32 %r3, %r0, %r1, %r2;

    // 2. Load destination pointer 'c'
    ld.param.u64 %rd1, [c];

    // 3. Calculate memory offset (index * 4 bytes)
    mul.wide.u32 %rd2, %r3, 4;
    add.u64 %rd3, %rd1, %rd2;

    // 4. Convert integer index to float (e.g., 5 -> 5.0)
    cvt.rn.f32.u32 %f1, %r3;

    // 5. Write to memory
    st.global.f32 [%rd3], %f1;

    ret;
}