.version 7.8
.target sm_61
.address_size 64

.visible .entry pointertest(.param .u64 a, .param .u64 b, .param .u64 c, .param .u64 n)
{
    .reg .b64 %ra, %rb, %rc, %rd_out;

    // Load the pointers themselves
    ld.param.u64 %ra, [a];
    ld.param.u64 %rb, [b];
    ld.param.u64 %rc, [c];

    // Use 'c' as the destination to store all three addresses
    // We'll store them as a sequence of 8-byte values
    st.global.u64 [%rc],     %ra;
    st.global.u64 [%rc+8],   %rb;
    st.global.u64 [%rc+16],  %rc;
    
    ret;
}